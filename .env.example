# PostgreSQL password — use a strong random string
POSTGRES_PASSWORD=change_me_strong_db_password

# JWT signing secrets — use long random strings (min 32 chars each)
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_strong_jwt_secret_min_32_characters
JWT_REFRESH_SECRET=change_me_strong_refresh_secret_min_32_characters

# Token expiry (optional — these are the defaults)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public URL of your deployment (used for CORS and certificate verification links)
FRONTEND_URL=https://your-domain.com

# Port to expose the app on the host (default: 80)
APP_PORT=80

# Container registry and image tag (used by docker compose and Makefile)
# Examples:
#   REGISTRY=docker.io/your-org
#   REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
#   REGISTRY=gcr.io/your-project
REGISTRY=parish-app
IMAGE_TAG=latest
